{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "128000"
  },
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(git log:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir -p ~/.local/bin ~/.claude)",
      "Bash(cp /Users/nrb/.claude/plugins/cache/starship-claude/starship-claude/1.0.0/bin/starship-claude ~/.local/bin/starship-claude)",
      "Bash(chmod +x ~/.local/bin/starship-claude)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "ci@ai-helpers": true,
    "must-gather@ai-helpers": true,
    "jira@ai-helpers": true,
    "golang@ai-helpers": true,
    "workspaces@ai-helpers": true,
    "gopls-lsp@ai-helpers": true
  },
  "extraKnownMarketplaces": {
    "ai-helpers": {
      "source": {
        "source": "github",
        "repo": "openshift-eng/ai-helpers"
      }
    }
  }
}
